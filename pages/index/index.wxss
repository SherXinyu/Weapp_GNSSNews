.home {
  min-height: 100vh;
  padding: 72rpx 32rpx 48rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 112, 23, 0.24), transparent 34%),
    linear-gradient(180deg, #171a20 0%, #f4efe8 32%, #f4efe8 100%);
  box-sizing: border-box;
}

.hero {
  margin-top: 18rpx;
}

.brand {
  display: block;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.72);
}

.headline {
  display: block;
  margin-top: 18rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
}

.subhead {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.profile-card {
  margin-top: 72rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 20rpx 48rpx rgba(20, 28, 44, 0.12);
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ff7017 0%, #ff9d42 100%);
}

.profile-copy {
  display: flex;
  flex-direction: column;
}

.profile-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d2430;
}

.profile-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #687282;
}

.enter-btn {
  margin-top: 36rpx;
  border: none;
  border-radius: 999rpx;
  background: #ff7017;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-shadow: 0 16rpx 30rpx rgba(255, 112, 23, 0.28);
}
